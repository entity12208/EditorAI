{
  "geode": "5.6.1",
  "gd": {
    "win": "2.2081",
    "android": "2.2081",
    "mac": "2.2081",
    "ios": "2.2081"
  },
  "id": "entity12208.edit-ai",
  "name": "Editor AI",
  "version": "v2.1.9",
  "developer": "entity12208",
  "description": "Generate Geometry Dash levels using AI!",
  "dependencies": {
    "geode.node-ids": ">=v1.0.0"
  },
  "incompatibilities": {
    "alk.editor-collab": {
      "breaking": false,
      "version": "*"
    }
  },
  "settings": {
    "info-setting": {
      "type": "title",
      "name": "All settings are configured in-game via the gear icon in the AI popup."
    },
    "ai-provider":              { "type": "string", "default": "gemini" },
    "difficulty":               { "type": "string", "default": "medium" },
    "style":                    { "type": "string", "default": "modern" },
    "length":                   { "type": "string", "default": "medium" },
    "max-objects":              { "type": "int",    "default": 500, "min": 10, "max": 1000000 },
    "spawn-batch-size":         { "type": "int",    "default": 8,   "min": 1,  "max": 100 },
    "gemini-model":             { "type": "string", "default": "gemini-2.5-flash" },
    "gemini-api-key":           { "type": "string", "default": "" },
    "claude-model":             { "type": "string", "default": "claude-sonnet-4-6" },
    "claude-api-key":           { "type": "string", "default": "" },
    "openai-model":             { "type": "string", "default": "gpt-4o" },
    "openai-api-key":           { "type": "string", "default": "" },
    "ministral-model":          { "type": "string", "default": "ministral-8b-latest" },
    "ministral-api-key":        { "type": "string", "default": "" },
    "huggingface-model":        { "type": "string", "default": "meta-llama/Llama-3.1-8B-Instruct" },
    "huggingface-api-key":      { "type": "string", "default": "" },
    "openrouter-model":         { "type": "string", "default": "google/gemini-2.5-flash" },
    "openrouter-api-key":       { "type": "string", "default": "" },
    "deepseek-model":           { "type": "string", "default": "deepseek-chat" },
    "deepseek-api-key":         { "type": "string", "default": "" },
    "use-platinum":             { "type": "bool",   "default": false },
    "ollama-model":             { "type": "string", "default": "entity12208/editorai:deepseek" },
    "ollama-timeout":           { "type": "int",    "default": 600, "min": 60, "max": 1800 },
    "lm-studio-url":            { "type": "string", "default": "http://localhost:1234" },
    "lm-studio-model":          { "type": "string", "default": "default" },
    "llama-cpp-url":            { "type": "string", "default": "http://localhost:8080" },
    "llama-cpp-model":          { "type": "string", "default": "default" },
    "enable-rate-limiting":     { "type": "bool",   "default": true },
    "rate-limit-seconds":       { "type": "int",    "default": 3,   "min": 1,  "max": 60 },
    "enable-advanced-features": { "type": "bool",   "default": false },
    "enable-rating":            { "type": "bool",   "default": true },
    "max-feedback-examples":    { "type": "int",    "default": 3,   "min": 1,  "max": 10 }
  },
  "tags": [
    "editor",
    "utility",
    "content"
  ],
  "links": {
    "source": "https://github.com/Entity12208/EditorAI",
    "community": "https://discord.gg/5hwCqMUYNj",
    "homepage": "https://editorai.pages.dev"
  }
}
